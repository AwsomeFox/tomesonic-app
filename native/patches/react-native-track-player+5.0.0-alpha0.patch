+    // OFFLINE cold-start playback: resolve a downloaded book's local file +
+    // resume position from the mirrored download entry (no server involved).
+    // Note: with JS alive the RemotePlayId path plays the full local session
+    // with exact progress; this is the JS-dead fallback.
+    private fun absResolveOfflinePlay(itemId: String, overrideSec: Double?): Pair<String, Long>? {
+        val d = absDownloads[itemId] ?: return null
+        if (d.folder == null || d.tracks.isEmpty()) return null
+        val target = overrideSec ?: d.currentTime
+        var chosen = d.tracks[0]
+        for (t in d.tracks) {
+            val (_, start, dur) = t
+            if (target >= start && (dur <= 0.0 || target < start + dur)) { chosen = t; break }
+        }
+        // Build a properly percent-encoded file:// URI. Raw string concat broke
+        // on spaces / # / % / ? in the folder path or filename (ExoPlayer then
+        // failed to open the URI). Strip any existing file:// prefix to get a
+        // filesystem path, then let Uri.fromFile encode each segment.
+        val folderPath = d.folder.trimEnd('/').removePrefix("file://")
+        val url = Uri.fromFile(java.io.File(folderPath, chosen.first)).toString()
+        val within = (target - chosen.second).coerceAtLeast(0.0)
+        Timber.i("AA offline play: %s -> %s @%ds", itemId, chosen.first, within.toLong())
+        // Remember the chosen track's offset (Triple.second = startOffset) so a
+        // later JS handoff (setupPlayer) can turn fakePlayer's track-relative
+        // position back into absolute book seconds — mirrors the online branch.
+        absColdStartOffsetMs = (chosen.second * 1000).toLong()
+        // Offline: no server session to sync (the persister will still refresh
+        // the local widget_state.json mirror). Record item/duration anyway.
+        absColdStartSessionId = null
+        absColdStartItemId = itemId
+        absColdStartDurationSec = d.duration
+        return Pair(url, (within * 1000).toLong())
+    }
