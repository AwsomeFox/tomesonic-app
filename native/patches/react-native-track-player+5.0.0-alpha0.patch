+        val libsBody = absGet("/api/libraries") ?: return emptyList()
+        val libs = org.json.JSONObject(libsBody).optJSONArray("libraries") ?: return emptyList()
+        val out = mutableListOf<MediaItem>()
+        val seen = HashSet<String>()
+        for (i in 0 until libs.length()) {
+            val libId = libs.getJSONObject(i).optString("id")
+            val pBody = absGet("/api/libraries/$libId/personalized?limit=25") ?: continue
+            val shelves = try { org.json.JSONArray(pBody) } catch (e: Exception) { continue }
+            for (j in 0 until shelves.length()) {
+                val shelf = shelves.getJSONObject(j)
+                if (shelf.optString("id") == "continue-series") {
+                    val entities = shelf.optJSONArray("entities") ?: continue
+                    for (k in 0 until entities.length()) {
+                        val ent = entities.getJSONObject(k)
+                        val series = ent.optJSONObject("media")?.optJSONObject("metadata")?.optJSONObject("series")
+                        val sid = series?.optString("id") ?: continue
+                        if (sid.isEmpty() || !seen.add("$libId:$sid")) continue
+                        val sname = series.optString("name", "Series")
+                        val coverId = ent.optString("id")
+                        out.add(absBrowsableItem("series:$libId:$sid", sname, "Series", "/api/items/$coverId/cover"))
+                    }
+                }
+            }
+        }
+        return out
+    }
