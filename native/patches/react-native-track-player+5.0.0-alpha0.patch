+            val cls = Class.forName("androidx.media3.session.MediaSession")
+            val field = cls.getDeclaredField("SESSION_ID_TO_SESSION_MAP")
+            field.isAccessible = true
+            val map = field.get(null) as? MutableMap<*, *>
+            if (map != null && map.isNotEmpty()) {
