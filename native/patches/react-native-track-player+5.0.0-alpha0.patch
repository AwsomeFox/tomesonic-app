+    private fun absResolvePlayResumable(
+        itemId: String,
+        episodeId: String?,
+        overrideSec: Double?
+    ): Pair<String, Long>? {
+        // Default the handoff offset to 0 (correct for single-file books and the
+        // offline path below); the online multi-file branch overwrites it with
+        // the chosen track's real startOffset before returning.
+        absColdStartOffsetMs = 0L
+        // Reset the persister's session identity for this resolve; the online
+        // branch below fills in the server session id + duration (the offline
+        // branch sets item/duration and leaves the session id null).
+        absColdStartSessionId = null
+        absColdStartItemId = itemId
+        absColdStartEpisodeId = episodeId
+        absColdStartDurationSec = 0.0
+        // Offline (or the server unreachable below): play the downloaded copy.
+        if (!absOnline() && episodeId == null) {
+            absResolveOfflinePlay(itemId, overrideSec)?.let { return it }
+        }
+        val creds = absCreds() ?: return null
+        val path = if (episodeId != null) "/api/items/$itemId/play/$episodeId" else "/api/items/$itemId/play"
+        val body = absPost(path, "{\"mediaPlayer\":\"exo-player\"}")
+            ?: return if (episodeId == null) absResolveOfflinePlay(itemId, overrideSec) else null
+        val json = org.json.JSONObject(body)
+        val tracks = json.optJSONArray("audioTracks") ?: return null
+        if (tracks.length() == 0) return null
+        // The /play response IS an open ABS playback session — capture its id +
+        // total duration so the JS-dead persister can POST progress to
+        // /api/session/{id}/sync while fakePlayer plays (see the persister).
+        absColdStartSessionId = json.optString("id").ifEmpty { null }
+        absColdStartDurationSec = json.optDouble("duration", 0.0)
+        val target = overrideSec ?: json.optDouble("currentTime", 0.0)
+        // Find the track whose window contains the target position; fall back
+        // to the first track (single-file books, or target beyond the end).
+        var chosen = tracks.getJSONObject(0)
+        for (i in 0 until tracks.length()) {
+            val t = tracks.getJSONObject(i)
+            val start = t.optDouble("startOffset", 0.0)
+            val dur = t.optDouble("duration", 0.0)
+            if (target >= start && (dur <= 0.0 || target < start + dur)) {
+                chosen = t
+                break
+            }
+        }
+        val rel = chosen.optString("contentUrl")
+        if (rel.isEmpty()) return null
+        val full = if (rel.startsWith("http")) rel else "${creds.server}$rel"
+        val url = if (full.contains("token=")) full else full + (if (full.contains("?")) "&" else "?") + "token=${creds.token}"
+        val withinSec = (target - chosen.optDouble("startOffset", 0.0)).coerceAtLeast(0.0)
+        // Remember the chosen track's offset so a later JS handoff (setupPlayer)
+        // can turn fakePlayer's track-relative position back into absolute book
+        // seconds.
+        absColdStartOffsetMs = (chosen.optDouble("startOffset", 0.0) * 1000).toLong()
+        return Pair(url, (withinSec * 1000).toLong())
     }
 
