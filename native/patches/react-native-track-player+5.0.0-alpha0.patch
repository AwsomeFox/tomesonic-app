+                            s?.javaClass?.getMethod("release")?.invoke(s)
+                        } catch (e: Throwable) {
+                            Timber.w("release() on stale session failed: %s", e.message)
+                        }
+                        iter.remove()
+                    }
+                }
+            }
+        } catch (e: Throwable) {
+            // The reflected private field was renamed/removed on a Media3 bump,
+            // or access was denied. Surface it loudly (was a silent no-op) so the
+            // "Session ID must be unique" guard's failure is observable in logs.
+            Timber.e(e, "purgeStaleSessionRegistrations failed (reflection broken?): %s", e.message)
+        }
+    }
+
+    // ===== Android Auto browse (ABS library) =====
+    // Small pool: a single slow request must not queue every subsequent
+    // browse tap behind it (the car UI shows a spinner per folder).
+    private val absBrowseExecutor = java.util.concurrent.Executors.newFixedThreadPool(3)
+
+    // Submit browse/resolve work to the pool. Once the pool is shut down (service
+    // teardown, see onDestroy) execute() throws RejectedExecutionException — a
+    // browse/play callback racing teardown would then return a SettableFuture
+    // that never completes, hanging the controller. On rejection, complete the
+    // future inline via onReject (all callers pass a cheap, no-disk fallback).
+    private fun absSubmitBrowse(onReject: () -> Unit, task: () -> Unit) {
+        try {
+            absBrowseExecutor.execute(task)
+        } catch (e: java.util.concurrent.RejectedExecutionException) {
+            Timber.w(e, "browse executor rejected task; completing future inline")
+            onReject()
+        }
+    }
+
+    // Compute the [from, to) sub-list bounds for a browse page. Returning the
+    // full list for every page made paginating head units append the same rows
+    // repeatedly (duplicate entries). The toLong() arithmetic clamps so a hostile
+    // page/pageSize can't overflow Int into a negative index; a page past the end
+    // yields an empty (from == to), NOT out-of-range, window.
+    private fun absPageWindow(size: Int, page: Int, pageSize: Int): Pair<Int, Int> {
+        val from = (page.toLong() * pageSize.toLong())
+            .coerceIn(0L, size.toLong()).toInt()
+        val to = (from.toLong() + pageSize.toLong())
+            .coerceIn(from.toLong(), size.toLong()).toInt()
+        return Pair(from, to)
+    }
+
+    // Parsed "play:<itemId>[::<episodeId>][@@<bookmarkSeconds>]" Android Auto
+    // media id. bookmarkSeconds is the absolute-seconds override some ids carry.
+    private data class PlayMediaId(
+        val itemId: String,
+        val episodeId: String?,
+        val bookmarkSeconds: Double?
+    )
+
+    // Parse the "play:" media-id grammar used across the Android Auto callbacks.
+    // removePrefix is a no-op when "play:" is absent, matching every call site
+    // (each guards with startsWith("play:") first, so the prefix is present).
+    private fun parsePlayMediaId(mediaId: String): PlayMediaId {
+        val body = mediaId.removePrefix("play:")
+        val raw = body.substringBefore("@@")
+        val bookmarkSeconds = body.substringAfter("@@", "").toDoubleOrNull()
+        val itemId = raw.substringBefore("::")
+        val episodeId = if (raw.contains("::")) raw.substringAfter("::") else null
+        return PlayMediaId(itemId, episodeId, bookmarkSeconds)
+    }
+
+    // Holds a freshly-refreshed access token in memory so we don't keep hitting
+    // the file (the JS side rewrites the file too, but not while backgrounded).
+    @Volatile private var absTokenOverride: String? = null
+    // The server the override token was minted for. A refreshed token is only
+    // valid against the server it came from — when the user switches servers
+    // (auto_creds.json rewritten with a new address), the stale override must
+    // NOT be applied to the new server (it would 401 every browse/play).
+    @Volatile private var absTokenOverrideServer: String? = null
+
+    private data class AbsCreds(val server: String, val token: String, val refreshToken: String?)
+
+    private fun absParseCreds(file: java.io.File): AbsCreds? {
+        return try {
+            val o = org.json.JSONObject(file.readText())
+            val server = o.optString("server").trimEnd('/')
+            // Only honor the in-memory override when it belongs to THIS server.
+            val override = if (absTokenOverride != null && absTokenOverrideServer == server) absTokenOverride else null
+            val token = override ?: o.optString("token")
+            // isNull guard: a JS-written `refreshToken: null` would otherwise
+            // read back as the string "null" (org.json optString behavior).
+            val refresh = if (o.isNull("refreshToken")) null else o.optString("refreshToken").ifEmpty { null }
+            if (server.isEmpty() || token.isEmpty()) null else AbsCreds(server, token, refresh)
+        } catch (e: Exception) { null }
+    }
+
+    private fun absCreds(): AbsCreds? {
+        return try {
+            val f = java.io.File(filesDir, "auto_creds.json")
+            if (f.exists()) absParseCreds(f)?.let { return it }
+            // Crash-window recovery: the JS atomic write deletes the main file
+            // before renaming its temp into place, and its last-resort fallback
+            // is a direct write — so the main file can be MISSING or CORRUPT.
+            // Either way the fully-written temp still holds a complete pair:
+            // read it and promote it (Os.rename atomically replaces a corrupt
+            // main) rather than losing the sole rotated refresh-token pair.
+            val tmp = java.io.File(filesDir, "auto_creds.json.tmp")
+            if (!tmp.exists()) return null
+            val recovered = absParseCreds(tmp) ?: return null
+            try { android.system.Os.rename(tmp.absolutePath, f.absolutePath) } catch (_: Exception) {}
+            recovered
+        } catch (e: Exception) { null }
+    }
+
+    // Refresh the ABS access token natively using the stored refresh token, so
+    // browse keeps working even when the app JS has been backgrounded for hours.
+    @Synchronized
+    private fun absRefreshToken(): String? {
+        val creds = absCreds() ?: return null
+        val refresh = creds.refreshToken ?: return null
+        return try {
+            val conn = java.net.URL("${creds.server}/auth/refresh").openConnection() as java.net.HttpURLConnection
+            conn.requestMethod = "POST"
+            conn.setRequestProperty("x-refresh-token", refresh)
+            conn.setRequestProperty("Content-Type", "application/json")
+            conn.connectTimeout = 8000; conn.readTimeout = 12000
+            conn.doOutput = true
+            conn.outputStream.use { it.write("{}".toByteArray()) }
+            if (conn.responseCode !in 200..299) { Timber.w("absRefreshToken HTTP %d", conn.responseCode); return null }
+            val resp = org.json.JSONObject(conn.inputStream.bufferedReader().readText())
+            val newToken = resp.optJSONObject("user")?.optString("accessToken")?.ifEmpty { null } ?: return null
+            val newRefresh = resp.optJSONObject("user")?.optString("refreshToken")?.ifEmpty { null } ?: refresh
+            absTokenOverride = newToken
+            // Scope the override to the server it was minted for (see field doc).
+            absTokenOverrideServer = creds.server
+            // Persist so subsequent cold starts also get the fresh token.
+            try {
+                val f = java.io.File(filesDir, "auto_creds.json")
+                val o = if (f.exists()) org.json.JSONObject(f.readText()) else org.json.JSONObject()
+                o.put("server", creds.server); o.put("token", newToken); o.put("refreshToken", newRefresh)
+                // Atomic replace: ABS rotates the refresh token on every refresh,
+                // so this file can hold the ONLY valid pair — a torn write (a
+                // concurrent JS rewrite, or a process kill mid-write) would lose it
+                // and force a logout. Write a temp then POSIX-rename over the
+                // destination: Os.rename atomically REPLACES an existing file (no
+                // File.renameTo "false when dest exists" caveat), and because the
+                // readers here (native absCreds + the JS side) do plain reads, an
+                // atomic path swap — not AtomicFile, whose guarantee only covers
+                // AtomicFile.openRead() readers — is what keeps them from ever
+                // seeing a half-written file.
+                val tmp = java.io.File(filesDir, "auto_creds.json.tmp")
+                tmp.writeText(o.toString())
+                try {
+                    android.system.Os.rename(tmp.absolutePath, f.absolutePath)
+                } catch (re: Exception) {
+                    // Rename failed (unexpected) — fall back to a direct write so
+                    // the fresh token still persists, then drop the temp.
+                    Timber.w(re, "auto_creds atomic rename failed; direct write")
+                    f.writeText(o.toString()); tmp.delete()
+                }
+            } catch (e: Exception) { Timber.w(e, "absRefreshToken persist failed") }
+            // Cached browse/search MediaItems embed the OLD token in their online
+            // cover URIs (?token=...); drop them so the car re-fetches tiles with
+            // the fresh token instead of rendering 401/blank covers until they age
+            // out. (Connectivity flips already clear these, but a token rotation
+            // does not, so clear here too.) ConcurrentHashMap.clear() is safe from
+            // this background thread; absNotifyBrowseChanged posts the browse
+            // refresh onto the main thread (mediaSession is main-thread-only).
+            absChildrenCache.clear()
+            absSearchCache.clear()
+            absNotifyBrowseChanged("token refresh")
+            Timber.i("absRefreshToken: refreshed access token natively")
+            newToken
+        } catch (e: Exception) { Timber.w(e, "absRefreshToken failed"); null }
+    }
+
+    private fun absRequest(method: String, path: String, body: String?, allowRefresh: Boolean = true): String? {
+        val creds = absCreds() ?: return null
+        return try {
+            val conn = java.net.URL("${creds.server}$path").openConnection() as java.net.HttpURLConnection
+            conn.requestMethod = method
+            conn.setRequestProperty("Authorization", "Bearer ${creds.token}")
+            // Snappy failure matters in a car: the browse cache serves stale
+            // results when this times out, which beats a 20s spinner.
+            conn.connectTimeout = 5000; conn.readTimeout = 10000
+            if (body != null) {
+                conn.doOutput = true
+                conn.setRequestProperty("Content-Type", "application/json")
+                conn.outputStream.use { it.write(body.toByteArray()) }
+            }
+            val code = conn.responseCode
+            when {
+                code in 200..299 -> conn.inputStream.bufferedReader().readText()
+                code == 401 && allowRefresh && absRefreshToken() != null -> absRequest(method, path, body, allowRefresh = false)
+                else -> { Timber.w("absRequest %s %s HTTP %d", method, path, code); null }
+            }
+        } catch (e: Exception) { Timber.w(e, "absRequest %s %s failed", method, path); null }
+    }
+
+    private fun absGet(path: String): String? = absRequest("GET", path, null)
+
+    private fun absPost(path: String, body: String): String? = absRequest("POST", path, body)
+
+    private fun absArtwork(path: String): Uri? {
+        val creds = absCreds() ?: return null
+        return Uri.parse("${creds.server}$path?token=${creds.token}")
+    }
