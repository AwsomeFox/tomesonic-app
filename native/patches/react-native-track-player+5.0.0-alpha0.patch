+
+    private fun absBrowsableItem(
+        id: String,
+        title: String,
+        subtitle: String? = null,
+        artworkPath: String? = null,
+        iconRes: String? = null,
+        childPlayableStyle: Int? = null,
+        childBrowsableStyle: Int? = null
+    ): MediaItem {
+        val md = androidx.media3.common.MediaMetadata.Builder()
+            .setTitle(title).setIsBrowsable(true).setIsPlayable(false)
+            .setMediaType(androidx.media3.common.MediaMetadata.MEDIA_TYPE_FOLDER_MIXED)
+        if (!subtitle.isNullOrEmpty()) md.setSubtitle(subtitle)
+        if (artworkPath != null) absArtwork(artworkPath)?.let { md.setArtworkUri(it) }
+        // Category icon from an app drawable (android.resource URI) — used for
+        // the root/library category folders so browsing scans faster in the car.
+        if (artworkPath == null && iconRes != null) {
+            md.setArtworkUri(Uri.parse("android.resource://$packageName/drawable/$iconRes"))
+        }
+        if (childPlayableStyle != null || childBrowsableStyle != null) {
+            val extras = android.os.Bundle()
+            childPlayableStyle?.let { extras.putInt("android.media.browse.CONTENT_STYLE_PLAYABLE_HINT", it) }
+            childBrowsableStyle?.let { extras.putInt("android.media.browse.CONTENT_STYLE_BROWSABLE_HINT", it) }
+            md.setExtras(extras)
+        }
+        return MediaItem.Builder().setMediaId(id).setMediaMetadata(md.build()).build()
+    }
+
+    // Null-safe optString: org.json returns the STRING "null" for explicit
+    // JSON nulls, which would render literally in the car UI.
+    private fun absStr(o: org.json.JSONObject?, key: String): String? {
+        if (o == null || o.isNull(key)) return null
+        return o.optString(key).ifEmpty { null }
+    }
+
+    // A book item is Android-Auto-relevant only if it has AUDIO — ebook-only
+    // items (and items whose progress is reading-only) are filtered everywhere.
+    // Handles both minified (numTracks/numAudioFiles) and expanded (arrays)
+    // media payloads.
+    private fun absHasAudio(mediaObj: org.json.JSONObject?): Boolean {
+        if (mediaObj == null) return false
+        if (mediaObj.optInt("numTracks", 0) > 0) return true
+        if (mediaObj.optInt("numAudioFiles", 0) > 0) return true
+        if ((mediaObj.optJSONArray("tracks")?.length() ?: 0) > 0) return true
+        if ((mediaObj.optJSONArray("audioFiles")?.length() ?: 0) > 0) return true
+        return mediaObj.optDouble("duration", 0.0) > 0.0
+    }
+
+    // Android Auto natively renders a checkmark / progress bar / download icon
+    // from these legacy MediaDescription extras (Media3 forwards metadata
+    // extras to the legacy browser AA uses). Values per androidx.media
+    // MediaConstants / MediaDescriptionCompat.
+    private fun absItemExtras(prog: org.json.JSONObject?, downloaded: Boolean): android.os.Bundle {
+        val b = android.os.Bundle()
+        if (downloaded) {
+            b.putLong("android.media.extra.DOWNLOAD_STATUS", 2L) // STATUS_DOWNLOADED
+        }
+        if (prog != null) {
+            val finished = prog.optBoolean("isFinished", false)
+            val duration = prog.optDouble("duration", 0.0)
+            val current = prog.optDouble("currentTime", 0.0)
+            // Key strings verified against media3 1.8 MediaConstants — the
+            // "obvious" android.media.description.extra.* names are wrong and
+            // render nothing (DESCRIPTION_EXTRAS_KEY_COMPLETION_STATUS is
+            // literally "android.media.extra.PLAYBACK_STATUS").
+            when {
+                finished -> b.putInt("android.media.extra.PLAYBACK_STATUS", 2) // checkmark
+                current > 0 && duration > 0 -> {
+                    b.putInt("android.media.extra.PLAYBACK_STATUS", 1) // partially played
+                    b.putDouble(
+                        "androidx.media.MediaItem.Extras.COMPLETION_PERCENTAGE",
+                        (current / duration).coerceIn(0.0, 1.0)
+                    )
+                }
+            }
+        }
+        return b
+    }
+
+    // Downloaded books, mirrored by JS into auto_downloads.json — rich entries
+    // (title/author/local files/resume time) so the car can browse AND play
+    // them fully offline. Legacy id-array files still parse (badge-only).
+    private data class AbsDownload(
+        val id: String,
+        val title: String,
+        val author: String?,
+        val folder: String?,
+        val coverPath: String?,
+        val currentTime: Double,
+        val duration: Double,
+        val tracks: List<Triple<String, Double, Double>> // filename, startOffset, duration
+    )
+
+    @Volatile private var absDownloads: Map<String, AbsDownload> = emptyMap()
+
+    // Mirror files are swapped by JS via delete-then-rename (its moveAsync
+    // rejects on an existing destination): a read landing between the delete
+    // and the rename finds NO main file even though a fully-written .tmp
+    // exists. Fall back to the temp instead of treating the gap as "absent" —
+    // that wiped the offline catalog / resume state for a browse cycle.
+    private fun absReadMirror(name: String): String? {
+        val f = java.io.File(filesDir, name)
+        if (f.exists()) {
+            try { return f.readText() } catch (_: Exception) {}
+        }
+        val tmp = java.io.File(filesDir, "$name.tmp")
+        if (tmp.exists()) {
+            try { return tmp.readText() } catch (_: Exception) {}
+        }
+        return null
+    }
+
+    // Parse the auto_downloads.json mirror into the offline catalog map. Two row
+    // shapes coexist: legacy bare-string ids (badge only, no offline play) and
+    // rich JSONObject rows carrying title/author/folder/cover + a tracks[] list.
+    // Extracted verbatim from absRefreshDownloaded so it is unit-testable; the
+    // "keep last good map on throw" recovery stays in the caller's wrapper.
+    private fun parseAutoDownloads(arr: org.json.JSONArray): Map<String, AbsDownload> {
+        val out = HashMap<String, AbsDownload>()
+        for (i in 0 until arr.length()) {
+            val v = arr.opt(i)
+            if (v is String) {
+                // Legacy format: bare item id (badge only, no offline play).
+                out[v] = AbsDownload(v, "Audiobook", null, null, null, 0.0, 0.0, emptyList())
+            } else if (v is org.json.JSONObject) {
+                val id = v.optString("id")
+                if (id.isEmpty()) continue
+                val tracks = mutableListOf<Triple<String, Double, Double>>()
+                v.optJSONArray("tracks")?.let { ts ->
+                    for (j in 0 until ts.length()) {
+                        val t = ts.getJSONObject(j)
+                        tracks.add(Triple(t.optString("filename"), t.optDouble("startOffset", 0.0), t.optDouble("duration", 0.0)))
+                    }
+                }
+                out[id] = AbsDownload(
+                    id,
+                    v.optString("title", "Audiobook"),
+                    v.optString("author").ifEmpty { null },
+                    v.optString("folder").ifEmpty { null },
+                    v.optString("coverPath").ifEmpty { null },
+                    v.optDouble("currentTime", 0.0),
+                    v.optDouble("duration", 0.0),
+                    tracks
                 )
+            }
+        }
+        return out
+    }
+
+    private fun absRefreshDownloaded() {
+        absDownloads = try {
+            val raw = absReadMirror("auto_downloads.json")
+            if (raw == null) {
+                // Neither main nor temp readable: fresh install (nothing
+                // downloaded yet — previous map is already empty) or a read
+                // mid-swap — keep the last good map either way.
+                absDownloads
+            } else {
+                // JSONArray(raw) can throw on a torn read — inside the try so the
+                // catch below preserves the last good map.
+                parseAutoDownloads(org.json.JSONArray(raw))
+            }
+        } catch (e: Exception) {
+            // JS rewrites this file every ~15s while a downloaded book plays;
+            // a torn read must not wipe the catalog — keep the last good map
+            // so offline browse/tap-to-play keeps working mid-drive.
+            Timber.w(e, "auto_downloads parse failed; keeping previous map")
+            absDownloads
+        }
+    }
+
+    // ===== Connectivity: offline browse falls back to downloads; when the
+    // network returns, notifyChildrenChanged re-adds the online catalog. =====
+    @Volatile private var absNetworkAvailable = true
+
+    private fun absOnline(): Boolean = absNetworkAvailable
+
+    private var absNetworkCallback: android.net.ConnectivityManager.NetworkCallback? = null
+
+    private fun absRegisterNetworkCallback() {
+        try {
+            val cm = getSystemService(android.content.Context.CONNECTIVITY_SERVICE) as android.net.ConnectivityManager
+            // Seed the flag from current state so a cold start in the garage
+            // (no signal) immediately browses offline.
+            absNetworkAvailable = cm.activeNetwork?.let { n ->
+                cm.getNetworkCapabilities(n)?.let { c ->
+                    c.hasCapability(android.net.NetworkCapabilities.NET_CAPABILITY_INTERNET) &&
+                        c.hasCapability(android.net.NetworkCapabilities.NET_CAPABILITY_VALIDATED)
+                } == true
+            } ?: false
+            val cb = object : android.net.ConnectivityManager.NetworkCallback() {
+                // A network becoming the default does NOT mean it reaches the
+                // internet — a captive-portal Wi-Fi or a no-service cellular
+                // attach both fire onAvailable, and both advertise
+                // NET_CAPABILITY_INTERNET even though no traffic actually flows.
+                // Marking browse ONLINE for those pins Android Auto to the online
+                // tree, whose server fetches then hang/fail (15-45s spinner).
+                // Require the framework to have actually VALIDATED the link (a
+                // real reachability probe succeeded) in addition to INTERNET, so
+                // captive-portal/dead-zone attaches count as offline and we
+                // surface downloaded books instead. onCapabilitiesChanged flips
+                // it once the link validates (captive portal signed in, or
+                // service comes up).
+                private fun hasInternet(n: android.net.Network): Boolean =
+                    cm.getNetworkCapabilities(n)?.let { c ->
+                        c.hasCapability(android.net.NetworkCapabilities.NET_CAPABILITY_INTERNET) &&
+                            c.hasCapability(android.net.NetworkCapabilities.NET_CAPABILITY_VALIDATED)
+                    } == true
+
+                override fun onAvailable(network: android.net.Network) {
+                    val was = absNetworkAvailable
+                    val up = hasInternet(network)
+                    absNetworkAvailable = up
+                    if (up && !was) absNotifyBrowseChanged("network available")
+                    else if (!up && was) absNotifyBrowseChanged("network available without internet")
+                }
+                override fun onCapabilitiesChanged(
+                    network: android.net.Network,
+                    caps: android.net.NetworkCapabilities
+                ) {
+                    val up = caps.hasCapability(android.net.NetworkCapabilities.NET_CAPABILITY_INTERNET) &&
+                        caps.hasCapability(android.net.NetworkCapabilities.NET_CAPABILITY_VALIDATED)
+                    if (up != absNetworkAvailable) {
+                        absNetworkAvailable = up
+                        absNotifyBrowseChanged(if (up) "internet validated" else "internet dropped")
+                    }
+                }
+                override fun onLost(network: android.net.Network) {
+                    val cmNow = getSystemService(android.content.Context.CONNECTIVITY_SERVICE) as android.net.ConnectivityManager
+                    // Same INTERNET+VALIDATED check as the seed above — a
+                    // lingering captive-portal/no-internet transport must not
+                    // keep browse pinned to online mode.
+                    val stillUp = cmNow.activeNetwork?.let { n ->
+                        cmNow.getNetworkCapabilities(n)?.let { c ->
+                            c.hasCapability(android.net.NetworkCapabilities.NET_CAPABILITY_INTERNET) &&
+                                c.hasCapability(android.net.NetworkCapabilities.NET_CAPABILITY_VALIDATED)
+                        } == true
+                    } ?: false
+                    val was = absNetworkAvailable
+                    absNetworkAvailable = stillUp
+                    if (was && !stillUp) absNotifyBrowseChanged("network lost")
+                }
+            }
+            cm.registerDefaultNetworkCallback(cb)
+            absNetworkCallback = cb
+        } catch (e: Exception) { Timber.w(e, "network callback registration failed") }
+    }
+
+    private fun absUnregisterNetworkCallback() {
+        try {
+            absNetworkCallback?.let {
+                val cm = getSystemService(android.content.Context.CONNECTIVITY_SERVICE) as android.net.ConnectivityManager
+                cm.unregisterNetworkCallback(it)
+            }
+        } catch (_: Exception) {}
+        absNetworkCallback = null
+    }
+
+    // Tell every connected browser (Android Auto) the tree changed so it
+    // re-queries — used when connectivity flips either way.
+    private fun absNotifyBrowseChanged(reason: String) {
+        // The ConnectivityManager callback fires on a background thread, but the
+        // MediaLibrarySession may only be touched on the main thread — post there
+        // (the previous off-thread call threw IllegalStateException, which the
+        // catch swallowed, so the online<->offline browse refresh silently never
+        // happened).
+        android.os.Handler(android.os.Looper.getMainLooper()).post {
+            if (absDestroyed || !::mediaSession.isInitialized) return@post
+            try {
+                Timber.i("AA browse: notifyChildrenChanged (%s)", reason)
+                // A connectivity flip invalidates everything cached: an online tree
+                // must never be served while offline, and vice versa. Search
+                // results too — stale online hits (server-URL artwork) would
+                // otherwise be served offline via onGetSearchResult.
+                absChildrenCache.clear()
+                absProgressCache = null
+                absSearchCache.clear()
+                mediaSession.notifyChildrenChanged("__ROOT__", Int.MAX_VALUE, null)
+                mediaSession.notifyChildrenChanged("__DOWNLOADS__", Int.MAX_VALUE, null)
+            } catch (e: Exception) { Timber.w(e, "notifyChildrenChanged failed") }
+        }
+    }
+
+    // Downloaded covers, decoded + scaled once and inlined as BYTES: Android
+    // Auto's process cannot read this app's private files, so a file:// art
+    // URI renders as a BLANK tile — bytes pass through the session bridge.
+    private val absArtCache = java.util.concurrent.ConcurrentHashMap<String, ByteArray>()
+
+    private fun absLocalArtBytes(itemId: String): ByteArray? {
+        absArtCache[itemId]?.let { return it }
+        val cover = absDownloads[itemId]?.coverPath ?: return null
+        val path = cover.removePrefix("file://")
+        // Only decode real filesystem paths. A non-file URI (http(s)://,
+        // content://, …) that ever lands in auto_downloads.json would otherwise
+        // drive BitmapFactory.decodeFile() into exception-driven control flow and
+        // per-lookup log spam.
+        if (!path.startsWith("/")) return null
+        return try {
+            val bounds = android.graphics.BitmapFactory.Options().apply { inJustDecodeBounds = true }
+            android.graphics.BitmapFactory.decodeFile(path, bounds)
+            var sample = 1
+            while (maxOf(bounds.outWidth, bounds.outHeight) / (sample * 2) >= 512) sample *= 2
+            val opts = android.graphics.BitmapFactory.Options().apply { inSampleSize = sample }
+            val bmp = android.graphics.BitmapFactory.decodeFile(path, opts) ?: return null
+            val out = java.io.ByteArrayOutputStream()
+            bmp.compress(android.graphics.Bitmap.CompressFormat.JPEG, 82, out)
+            bmp.recycle()
+            val bytes = out.toByteArray()
+            if (absArtCache.size < 60) absArtCache[itemId] = bytes
+            bytes
+        } catch (e: Exception) { Timber.w(e, "local art decode failed for %s", itemId); null }
+    }
+
+    private fun absPlayableItem(
+        mediaId: String,
+        coverItemId: String,
+        title: String,
+        author: String?,
+        subtitle: String?,
+        prog: org.json.JSONObject? = null,
+        // When false, the offline cover is NOT inlined as bytes. Nodes that
+        // Android Auto subscribes to without pagination (e.g. Downloads) cap
+        // how many tiles carry inlined artwork so the combined bytes don't
+        // overflow the Binder transaction (TransactionTooLargeException).
+        inlineArt: Boolean = true
+    ): MediaItem {
+        val creds = absCreds()
+        val downloaded = absDownloads.containsKey(coverItemId)
+        // Progress state goes at the FRONT of the title ("42% • Critical Mass",
+        // "✓ Critical Mass") — car screens truncate subtitles so early that
+        // trailing progress text never showed, the native badges are
+        // unreliable across head units, and the cover already identifies the
+        // book.
+        val pct = absProgressPct(prog)
+        val displayTitle = when {
+            prog?.optBoolean("isFinished", false) == true -> "✓ $title"
+            pct != null -> "$pct% • $title"
+            else -> title
+        }
+        val md = androidx.media3.common.MediaMetadata.Builder()
+            .setTitle(displayTitle).setArtist(author ?: "")
+            .setIsBrowsable(false).setIsPlayable(true)
+            .setMediaType(androidx.media3.common.MediaMetadata.MEDIA_TYPE_AUDIO_BOOK)
+            // Native badges: download icon, finished checkmark, progress bar.
+            .setExtras(absItemExtras(prog, downloaded))
+        // Artwork: server URL while online (the car loads http itself);
+        // offline, inline the downloaded cover as bytes — NEVER file:// (the
+        // car process can't read the app's private storage → blank tiles).
+        if (absOnline() && creds != null) {
+            md.setArtworkUri(Uri.parse("${creds.server}/api/items/$coverItemId/cover?token=${creds.token}"))
+        } else if (inlineArt) {
+            absLocalArtBytes(coverItemId)?.let {
+                md.setArtworkData(it, androidx.media3.common.MediaMetadata.PICTURE_TYPE_FRONT_COVER)
+            }
+        }
+        // inlineArt == false leaves the tile art-less rather than inlining
+        // bytes: a file:// cover URI would only render as a blank tile anyway
+        // (the car process can't read this app's private storage).
+        if (!subtitle.isNullOrEmpty()) md.setSubtitle(subtitle)
+        return MediaItem.Builder().setMediaId(mediaId).setMediaMetadata(md.build()).build()
+    }
+
+    // Progress maps from /api/me, cached ~15s — nearly every browse category
+    // needs them, and refetching per drill-in wastes time on flaky car links.
+    //   items:    itemId            -> mediaProgress (books)
+    //   episodes: "itemId-episodeId" -> mediaProgress (podcast episodes)
+    private data class AbsProgress(
+        val items: HashMap<String, org.json.JSONObject>,
+        val episodes: HashMap<String, org.json.JSONObject>
+    )
+
+    @Volatile private var absProgressCache: Pair<Long, AbsProgress>? = null
+
+    private fun absProgress(): AbsProgress {
+        val now = System.currentTimeMillis()
+        absProgressCache?.let { (at, p) -> if (now - at < 15_000) return p }
+        val items = HashMap<String, org.json.JSONObject>()
+        val episodes = HashMap<String, org.json.JSONObject>()
+        absGet("/api/me")?.let { meBody ->
+            org.json.JSONObject(meBody).optJSONArray("mediaProgress")?.let { mp ->
+                for (i in 0 until mp.length()) {
+                    val p = mp.getJSONObject(i)
+                    val itemId = p.optString("libraryItemId")
+                    if (itemId.isEmpty()) continue
+                    // org.json GOTCHA: optString on an explicit JSON null
+                    // returns the STRING "null" — books carry episodeId: null,
+                    // and treating that as an episode key silently emptied the
+                    // items map (killed time-left, checkmarks, finished counts).
+                    val epId = if (p.isNull("episodeId")) "" else p.optString("episodeId")
+                    if (epId.isNotEmpty()) episodes["$itemId-$epId"] = p
+                    else items[itemId] = p
+                }
+            }
+        }
+        val result = AbsProgress(items, episodes)
+        // Only cache non-empty results — an offline fetch shouldn't poison the
+        // cache with emptiness for 15s after the network returns.
+        if (items.isNotEmpty() || episodes.isNotEmpty()) absProgressCache = Pair(now, result)
+        return result
+    }
+
+    private fun absProgressMap(): HashMap<String, org.json.JSONObject> = absProgress().items
+
+    // Continue Listening: annotate each in-progress book with "author • Xh Ym left".
+    // Ebook-only items and items whose progress is READING-only are filtered —
+    // this category is about audio you can resume in the car.
+    private fun absContinueListening(): List<MediaItem> {
+        val body = absGet("/api/me/items-in-progress?limit=25") ?: return emptyList()
+        val arr = org.json.JSONObject(body).optJSONArray("libraryItems") ?: return emptyList()
+        val progById = absProgressMap()
+        return (0 until arr.length()).mapNotNull { i ->
+            val o = arr.getJSONObject(i)
+            val id = o.optString("id").ifEmpty { return@mapNotNull null }
+            if (!absHasAudio(o.optJSONObject("media"))) return@mapNotNull null
+            val prog = progById[id]
+            // Reading-only progress (ebook side of a dual-format book) doesn't
+            // belong in Continue LISTENING.
+            if (prog != null && prog.optDouble("currentTime", 0.0) <= 0.0 && !prog.optBoolean("isFinished", false)) return@mapNotNull null
+            val md = o.optJSONObject("media")?.optJSONObject("metadata")
+            val title = absStr(md, "title") ?: "Audiobook"
+            val author = absStr(md, "authorName")
+            // Android Auto renders the *artist* line under the title for playable
+            // items, so put the "author • Xh Ym left" progress there (and in the
+            // subtitle) to guarantee it shows.
+            val line = absProgressSubtitle(prog, author)
+            absPlayableItem("play:$id", id, title, line, line, prog)
+        }
+    }
+
+    // Downloaded books as a browse category — playable OFFLINE via local files.
+    // Android Auto subscribes to the Downloads node WITHOUT pagination
+    // (page=0, pageSize=MAX), so every item crosses the Binder in one
+    // transaction. Inlined cover bytes are large (~tens of KB each), and with
+    // many offline books the combined payload overflows the Binder limit
+    // (TransactionTooLargeException) → the node fails to load offline. Cap how
+    // many tiles carry inlined artwork; the rest stay listed and playable, just
+    // art-less. Keep this small so the whole node fits comfortably.
+    private val absDownloadsArtBudget = 8
+
+    private fun absDownloadsCategory(): List<MediaItem> {
+        val prog = if (absOnline()) absProgressMap() else HashMap()
+        return absDownloads.values
+            .filter { it.tracks.isNotEmpty() } // rich entries only (legacy = badge-only)
+            .sortedBy { it.title.lowercase() }
+            .mapIndexed { index, d ->
+                val p = prog[d.id]
+                val line = absProgressSubtitle(p, d.author)
+                // Only the first N tiles inline cover bytes (see budget above).
+                absPlayableItem("play:${d.id}", d.id, d.title, line, line, p, inlineArt = index < absDownloadsArtBudget)
+            }
+    }
+
+    // In-progress percent (1-99), or null when there's nothing meaningful to
+    // show. absPlayableItem prefixes it onto the TITLE.
+    private fun absProgressPct(prog: org.json.JSONObject?): Int? {
+        if (prog == null || prog.optBoolean("isFinished", false)) return null
+        val duration = prog.optDouble("duration", 0.0)
+        val current = prog.optDouble("currentTime", 0.0)
+        if (duration <= 0 || current <= 0) return null
+        return ((current / duration) * 100).toInt().coerceIn(1, 99)
+    }
+
+    private fun absProgressSubtitle(prog: org.json.JSONObject?, author: String?): String {
+        if (prog == null) return author ?: ""
+        if (prog.optBoolean("isFinished", false)) return if (author.isNullOrEmpty()) "Finished" else "$author • Finished"
+        val duration = prog.optDouble("duration", 0.0)
+        val current = prog.optDouble("currentTime", 0.0)
+        val remaining = duration - current
+        if (remaining <= 0 || current <= 0) return author ?: ""
+        val h = (remaining / 3600).toInt()
+        val m = ((remaining % 3600) / 60).toInt()
+        val left = if (h > 0) "${h}h ${m}m left" else "${m}m left"
+        // Percent lives in the title prefix (absPlayableItem); keep the
+        // subtitle short so "…left" survives car-screen truncation.
+        return if (author.isNullOrEmpty()) left else "$author • $left"
+    }
+
+    private fun absItemToMedia(o: org.json.JSONObject, prog: org.json.JSONObject? = null): MediaItem? {
+        val id = o.optString("id").ifEmpty { return null }
+        if (!absHasAudio(o.optJSONObject("media"))) return null // ebook-only: filtered everywhere
+        val md = o.optJSONObject("media")?.optJSONObject("metadata")
+        val title = absStr(md, "title") ?: absStr(o, "title") ?: "Audiobook"
+        val author = absStr(md, "authorName")
+        val series = absStr(md, "seriesName")
+        return absPlayableItem("play:$id", id, title, author, series, prog)
+    }
+
+    // ABS library-item filters are base64(id) of the entity id, URL-encoded (matches the web client).
+    private fun absB64(s: String): String =
+        java.net.URLEncoder.encode(
+            android.util.Base64.encodeToString(s.toByteArray(Charsets.UTF_8), android.util.Base64.NO_WRAP),
+            "UTF-8"
+        )
+
+    private fun absItemsFromResults(
+        path: String,
+        withProgress: Boolean = false,
+        sortByTitle: Boolean = false,
+        // Series drill-in: lead the subtitle with "Book N" (the sequence) —
+        // the author repeats on every tile there and says nothing useful.
+        sequenceSubtitle: Boolean = false
+    ): List<MediaItem> {
+        val body = absGet(path) ?: return emptyList()
+        val arr = org.json.JSONObject(body).optJSONArray("results") ?: org.json.JSONArray()
+        val items: List<MediaItem> = if (!withProgress) {
+            (0 until arr.length()).mapNotNull { absItemToMedia(arr.getJSONObject(it)) }
+        } else {
+            val prog = absProgressMap()
+            (0 until arr.length()).mapNotNull { i ->
+                val o = arr.getJSONObject(i)
+                val id = o.optString("id").ifEmpty { return@mapNotNull null }
+                if (!absHasAudio(o.optJSONObject("media"))) return@mapNotNull null
+                val md = o.optJSONObject("media")?.optJSONObject("metadata")
+                val title = absStr(md, "title") ?: "Audiobook"
+                val author = absStr(md, "authorName")
+                val lead = if (sequenceSubtitle) absSequenceLabel(md) ?: author else author
+                val p = prog[id]
+                // Progress/"Finished" in the artist line (Android Auto shows it
+                // under the title); native checkmark/progress-bar via extras.
+                val line = absProgressSubtitle(p, lead)
+                absPlayableItem("play:$id", id, title, line, line, p)
+            }
+        }
+        return if (sortByTitle) items.sortedBy { (it.mediaMetadata.title ?: "").toString().lowercase() } else items
+    }
+
+    // "Book 3" from the item's series sequence. Series-filtered results carry
+    // it in metadata.series.sequence; minified rows fall back to the
+    // "Name #3" suffix on seriesName.
+    private fun absSequenceLabel(md: org.json.JSONObject?): String? {
+        val seq = md?.optJSONObject("series")?.let { absStr(it, "sequence") }
+            ?: absStr(md, "seriesName")?.substringAfterLast('#', "")?.trim()?.ifEmpty { null }
+        return seq?.let { "Book $it" }
+    }
+
+    private fun absItemsFiltered(
+        libId: String,
+        type: String,
+        id: String,
+        sort: String? = null,
+        withProgress: Boolean = false,
+        sequenceSubtitle: Boolean = false
+    ): List<MediaItem> {
+        var path = "/api/libraries/$libId/items?filter=$type.${absB64(id)}&limit=200&minified=1"
+        if (sort != null) path += "&sort=$sort"
+        return absItemsFromResults(path, withProgress, sequenceSubtitle = sequenceSubtitle)
+    }
+
+    private fun absLibraryCategories(parentId: String): List<MediaItem> {
+        // parentId = "lib:{id}:{mediaType}"
+        val rest = parentId.removePrefix("lib:")
+        val libId = rest.substringBefore(":")
+        val mediaType = rest.substringAfter(":", "book")
+        if (mediaType == "podcast") {
+            val body = absGet("/api/libraries/$libId/items?limit=200&minified=1") ?: return emptyList()
+            val arr = org.json.JSONObject(body).optJSONArray("results") ?: org.json.JSONArray()
+            return (0 until arr.length()).mapNotNull { absPodcastBrowsable(arr.getJSONObject(it)) }
+                .sortedBy { (it.mediaMetadata.title ?: "").toString().lowercase() }
+        }
+        return listOf(
+            absBrowsableItem("latest:$libId", "Recently Added", iconRes = "aa_recent", childPlayableStyle = STYLE_GRID),
+            absBrowsableItem("authors:$libId", "Authors", iconRes = "aa_author", childBrowsableStyle = STYLE_CATEGORY_LIST),
+            absBrowsableItem("serieslist:$libId", "Series", iconRes = "aa_series", childBrowsableStyle = STYLE_CATEGORY_LIST),
+            absBrowsableItem("collections:$libId", "Collections", iconRes = "aa_collections", childBrowsableStyle = STYLE_CATEGORY_LIST),
+            absBrowsableItem("listenagain:$libId", "Listen Again", iconRes = "aa_replay", childPlayableStyle = STYLE_GRID),
+            absBrowsableItem("allbooks:$libId", "All Books", iconRes = "aa_books", childPlayableStyle = STYLE_GRID)
+        )
+    }
+
+    // Continue Series: one browsable folder per series you're ACTIVE in —
+    // merged from (a) the server's continue-series shelf (finished one book,
+    // next one up) and (b) the series of books currently in progress, matching
+    // the app's bookshelf Continue Series row. Alphabetical by series name.
+    private fun absContinueSeries(): List<MediaItem> {
+        val libsBody = absGet("/api/libraries") ?: return emptyList()
+        val libs = org.json.JSONObject(libsBody).optJSONArray("libraries") ?: return emptyList()
+        data class Entry(val id: String, val name: String, val coverId: String)
+        val entries = mutableListOf<Entry>()
+        val seen = HashSet<String>()
+
+        // (b)'s series only carry a NAME on the item — resolve name -> id via
+        // each library's series list.
+        val nameToId = HashMap<String, String>() // "libId:name(lower)" -> "libId:seriesId"
+        for (i in 0 until libs.length()) {
+            val libId = libs.getJSONObject(i).optString("id")
+            if (libs.getJSONObject(i).optString("mediaType", "book") != "book") continue
+            absGet("/api/libraries/$libId/series?limit=1000&minified=1")?.let { sBody ->
+                org.json.JSONObject(sBody).optJSONArray("results")?.let { sArr ->
+                    for (j in 0 until sArr.length()) {
+                        val s = sArr.getJSONObject(j)
+                        val sid = s.optString("id")
+                        val sname = s.optString("name")
+                        if (sid.isNotEmpty() && sname.isNotEmpty()) nameToId["$libId:${sname.lowercase()}"] = "$libId:$sid"
+                    }
+                }
+            }
+
+            // (a) The server's between-books shelf.
+            absGet("/api/libraries/$libId/personalized?limit=25")?.let { pBody ->
+                val shelves = try { org.json.JSONArray(pBody) } catch (e: Exception) { null }
+                if (shelves != null) for (j in 0 until shelves.length()) {
+                    val shelf = shelves.getJSONObject(j)
+                    if (shelf.optString("id") != "continue-series") continue
+                    val entities = shelf.optJSONArray("entities") ?: continue
+                    for (k in 0 until entities.length()) {
+                        val ent = entities.getJSONObject(k)
+                        val series = ent.optJSONObject("media")?.optJSONObject("metadata")?.optJSONObject("series") ?: continue
+                        val sid = series.optString("id")
+                        if (sid.isEmpty() || !seen.add("$libId:$sid")) continue
+                        entries.add(Entry("series:$libId:$sid", series.optString("name", "Series"), ent.optString("id")))
+                    }
+                }
+            }
+        }
+
+        // (b) Series of books currently in progress (audio progress only).
+        absGet("/api/me/items-in-progress?limit=25")?.let { body ->
+            org.json.JSONObject(body).optJSONArray("libraryItems")?.let { arr ->
+                for (i in 0 until arr.length()) {
+                    val o = arr.getJSONObject(i)
+                    if (!absHasAudio(o.optJSONObject("media"))) continue
+                    val md = o.optJSONObject("media")?.optJSONObject("metadata") ?: continue
+                    // seriesName can carry a "#seq" suffix — strip it for lookup.
+                    val rawName = md.optString("seriesName")
+                    if (rawName.isEmpty()) continue
+                    val name = rawName.replace(Regex("\\s+#[\\d.]+\\s*$"), "").trim()
+                    val libId = o.optString("libraryId")
+                    val key = nameToId["$libId:${name.lowercase()}"] ?: continue
+                    if (!seen.add(key)) continue
+                    entries.add(Entry("series:$key", name, o.optString("id")))
+                }
+            }
+        }
+
+        // Subtitle each series with "X of Y finished" — the bounded set here
+        // (only ACTIVE series) keeps the per-series item queries cheap, and
+        // it's the most glanceable series info possible while driving.
+        val prog = absProgressMap()
+        return entries
+            .sortedBy { it.name.lowercase() }
+            .map { e ->
+                var subtitle = "Series"
+                val libId = e.id.removePrefix("series:").substringBefore(":")
+                val sid = e.id.substringAfterLast(":")
+                absGet("/api/libraries/$libId/items?filter=series.${absB64(sid)}&limit=100&minified=1")?.let { body ->
+                    org.json.JSONObject(body).optJSONArray("results")?.let { arr ->
+                        var total = 0; var finished = 0
+                        for (i in 0 until arr.length()) {
+                            val o = arr.getJSONObject(i)
+                            if (!absHasAudio(o.optJSONObject("media"))) continue
+                            total++
+                            if (prog[o.optString("id")]?.optBoolean("isFinished", false) == true) finished++
+                        }
+                        if (total > 0) subtitle = "$finished of $total finished"
+                    }
+                }
+                absBrowsableItem(e.id, e.name, subtitle, "/api/items/${e.coverId}/cover", childPlayableStyle = STYLE_GRID)
+            }
+    }
+
+    // Android Auto voice/text search across all libraries → playable books.
+    // Bounded insertion-order (FIFO) cache, cap 30 — accessOrder=false, so this
+    // is deliberately NOT an LRU: eviction ignores reads. onSearch fills it and
+    // the paged onGetSearchResult reads it back. Overflow evicts the OLDEST
+    // INSERTION automatically via removeEldestEntry — NEVER the just-inserted
+    // query (which FIFO guarantees without reads having to refresh recency) — so a
+    // different query filling the cache in the gap between onSearch and
+    // onGetSearchResult can't clear the pending query's results out from under
+    // it (the old clear()-everything-at-30 did exactly that). Wrapped in
+    // synchronizedMap because it's touched from the browse thread pool.
+    private val absSearchCache: MutableMap<String, List<MediaItem>> =
+        java.util.Collections.synchronizedMap(
+            object : java.util.LinkedHashMap<String, List<MediaItem>>(16, 0.75f, false) {
+                override fun removeEldestEntry(eldest: MutableMap.MutableEntry<String, List<MediaItem>>): Boolean =
+                    size > 30
+            }
+        )
+
+    private fun absSearch(query: String): List<MediaItem> {
+        val libsBody = absGet("/api/libraries") ?: return emptyList()
+        val libs = org.json.JSONObject(libsBody).optJSONArray("libraries") ?: return emptyList()
+        val q = java.net.URLEncoder.encode(query, "UTF-8")
+        val prog = absProgressMap()
+        val out = mutableListOf<MediaItem>()
+        val seen = HashSet<String>()
+        for (i in 0 until libs.length()) {
+            val libId = libs.getJSONObject(i).optString("id")
+            val body = absGet("/api/libraries/$libId/search?q=$q&limit=20") ?: continue
+            val books = org.json.JSONObject(body).optJSONArray("book") ?: continue
+            for (j in 0 until books.length()) {
+                val li = books.getJSONObject(j).optJSONObject("libraryItem") ?: continue
+                val id = li.optString("id")
+                if (id.isEmpty() || !seen.add(id)) continue
+                if (!absHasAudio(li.optJSONObject("media"))) continue // ebook-only: filtered
+                val md = li.optJSONObject("media")?.optJSONObject("metadata")
+                val title = absStr(md, "title") ?: "Audiobook"
+                val author = absStr(md, "authorName")
+                val p = prog[id]
+                val line = absProgressSubtitle(p, author)
+                out.add(absPlayableItem("play:$id", id, title, line, line, p))
+            }
+        }
+        return out
+    }
+
+    private fun absPodcastBrowsable(o: org.json.JSONObject): MediaItem? {
+        val id = o.optString("id").ifEmpty { return null }
+        val md = o.optJSONObject("media")?.optJSONObject("metadata")
+        val title = absStr(md, "title") ?: "Podcast"
+        val author = absStr(md, "author")
+        // Episode lists read best as text rows (titles are long, art repeats).
+        return absBrowsableItem("podcast:$id", title, author, "/api/items/$id/cover", childPlayableStyle = STYLE_LIST)
+    }
+
+    private fun absPodcastEpisodes(itemId: String): List<MediaItem> {
+        val body = absGet("/api/items/$itemId?expanded=1") ?: return emptyList()
+        val media = org.json.JSONObject(body).optJSONObject("media") ?: return emptyList()
+        val podTitle = absStr(media.optJSONObject("metadata"), "title")
+        val episodes = media.optJSONArray("episodes") ?: return emptyList()
+        val epProg = absProgress().episodes
+        // Newest first — that's how podcasts are consumed — capped so a
+        // 500-episode feed doesn't drown the car UI.
+        return (0 until episodes.length())
+            .mapNotNull { i -> episodes.getJSONObject(i) }
+            .sortedByDescending { it.optLong("publishedAt", 0L) }
+            .take(50)
+            .mapNotNull { ep ->
+                val epId = ep.optString("id")
+                if (epId.isEmpty()) return@mapNotNull null
+                val title = ep.optString("title", "Episode")
+                val p = epProg["$itemId-$epId"]
+                val line = absProgressSubtitle(p, podTitle)
+                absPlayableItem("play:$itemId::$epId", itemId, title, line, line, p)
+            }
+    }
+
+    // Browse cache: fresh entries serve instantly; on a FAILED refresh (dead
+    // zone mid-drive) stale entries keep the tree browsable instead of showing
+    // an empty screen. Cleared whenever connectivity flips (an online tree
+    // must never render while offline, and vice versa).
+    private data class AbsCacheEntry(val at: Long, val items: List<MediaItem>)
+    private val absChildrenCache = java.util.concurrent.ConcurrentHashMap<String, AbsCacheEntry>()
+    private val ABS_CACHE_FRESH_MS = 45_000L
+    private val ABS_CACHE_STALE_MS = 10 * 60_000L
