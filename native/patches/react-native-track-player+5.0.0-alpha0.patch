+        return try {
+            val conn = java.net.URL("${creds.server}$path").openConnection() as java.net.HttpURLConnection
+            conn.requestMethod = method
+            conn.setRequestProperty("Authorization", "Bearer ${creds.token}")
+            conn.connectTimeout = 8000; conn.readTimeout = 12000
+            if (body != null) {
+                conn.doOutput = true
+                conn.setRequestProperty("Content-Type", "application/json")
+                conn.outputStream.use { it.write(body.toByteArray()) }
+            }
+            val code = conn.responseCode
+            when {
+                code in 200..299 -> conn.inputStream.bufferedReader().readText()
+                code == 401 && allowRefresh && absRefreshToken() != null -> absRequest(method, path, body, allowRefresh = false)
+                else -> { Timber.w("absRequest %s %s HTTP %d", method, path, code); null }
+            }
+        } catch (e: Exception) { Timber.w(e, "absRequest %s %s failed", method, path); null }
+    }
