+
+    /**
+     * Resolves a direct-play stream URL AND the resume position for cold-start
+     * (JS-dead) playback. The /play response carries the server's saved
+     * `currentTime` (absolute book seconds); for multi-file books we pick the
+     * track containing that position and return the offset *within* it.
+     * `overrideSec`, when set (Android Auto bookmark "@@<seconds>" ids),
+     * replaces the server position.
+     */
+    private fun absResolvePlayResumable(
+        itemId: String,
+        episodeId: String?,
+        overrideSec: Double?
+    ): Pair<String, Long>? {
+        val creds = absCreds() ?: return null
+        val path = if (episodeId != null) "/api/items/$itemId/play/$episodeId" else "/api/items/$itemId/play"
+        val body = absPost(path, "{\"mediaPlayer\":\"exo-player\"}") ?: return null
+        val json = org.json.JSONObject(body)
+        val tracks = json.optJSONArray("audioTracks") ?: return null
+        if (tracks.length() == 0) return null
+        val target = overrideSec ?: json.optDouble("currentTime", 0.0)
+        // Find the track whose window contains the target position; fall back
+        // to the first track (single-file books, or target beyond the end).
+        var chosen = tracks.getJSONObject(0)
+        for (i in 0 until tracks.length()) {
+            val t = tracks.getJSONObject(i)
+            val start = t.optDouble("startOffset", 0.0)
+            val dur = t.optDouble("duration", 0.0)
+            if (target >= start && (dur <= 0.0 || target < start + dur)) {
+                chosen = t
+                break
+            }
+        }
+        val rel = chosen.optString("contentUrl")
+        if (rel.isEmpty()) return null
+        val full = if (rel.startsWith("http")) rel else "${creds.server}$rel"
+        val url = if (full.contains("token=")) full else full + (if (full.contains("?")) "&" else "?") + "token=${creds.token}"
+        val withinSec = (target - chosen.optDouble("startOffset", 0.0)).coerceAtLeast(0.0)
+        return Pair(url, (withinSec * 1000).toLong())
+    }
